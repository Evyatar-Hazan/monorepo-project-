{
  "name": "@monorepo/shared-ui-components",
  "version": "1.0.0",
  "description": "Shared React UI components library for all frontend applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/components/Button/Button.d.ts",
      "import": "./dist/components/Button/Button.js"
    },
    "./input": {
      "types": "./dist/components/Input/Input.d.ts",
      "import": "./dist/components/Input/Input.js"
    },
    "./modal": {
      "types": "./dist/components/Modal/Modal.d.ts",
      "import": "./dist/components/Modal/Modal.js"
    },
    "./loader": {
      "types": "./dist/components/Loader/Loader.d.ts",
      "import": "./dist/components/Loader/Loader.js"
    },
    "./card": {
      "types": "./dist/components/Card/Card.d.ts",
      "import": "./dist/components/Card/Card.js"
    },
    "./alert": {
      "types": "./dist/components/Alert/Alert.d.ts",
      "import": "./dist/components/Alert/Alert.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "shared",
    "monorepo"
  ],
  "author": "Evyatar Hazan",
  "license": "MIT"
}
